    class SimpleAudioPlayer {
        constructor(audioElement, playPauseBtn, timeDisplay, seekBar, volumeBar, errorSpan) {
            this.audio = audioElement;
            this.playPauseBtn = playPauseBtn;
            this.timeDisplay = timeDisplay;
            this.seekBar = seekBar;
            this.volumeBar = volumeBar;
            this.errorSpan = errorSpan;
            this.isPlaying = false;
            this.init();
        }
        
        init() {
            this.playPauseBtn.addEventListener('click', () => this.togglePlay());
            this.seekBar.addEventListener('input', (e) => this.seek(e.target.value));
            this.volumeBar.addEventListener('input', (e) => this.setVolume(e.target.value));
            this.audio.addEventListener('timeupdate', () => this.updateProgress());
            this.audio.addEventListener('ended', () => this.onEnded());
            this.audio.addEventListener('loadedmetadata', () => this.updateDuration());
            this.audio.addEventListener('canplay', () => this.onCanPlay());
            this.audio.addEventListener('error', (e) => this.onError(e));
            this.audio.volume = 0.7;
            this.volumeBar.value = 0.7;
        }
        
        togglePlay() {
            if (this.isPlaying) {
                this.audio.pause();
                this.playPauseBtn.textContent = '▶';
                this.isPlaying = false;
            } else {
                const playPromise = this.audio.play();
                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        this.playPauseBtn.textContent = '⏸';
                        this.isPlaying = true;
                        if (this.errorSpan) this.errorSpan.textContent = '';
                    }).catch(error => {
                        console.warn('Playback error:', error);
                        this.playPauseBtn.textContent = '▶';
                        this.isPlaying = false;
                        if (this.errorSpan) this.errorSpan.textContent = '⚠ cannot play';
                    });
                }
            }
        }
        
        seek(value) { this.audio.currentTime = parseFloat(value); }
        setVolume(value) { this.audio.volume = parseFloat(value); }
        
        updateProgress() {
            if (this.audio.duration && !isNaN(this.audio.duration)) {
                this.seekBar.value = this.audio.currentTime;
                this.seekBar.max = this.audio.duration;
                this.updateTimeDisplay();
            }
        }
        
        updateDuration() {
            if (this.audio.duration && !isNaN(this.audio.duration)) {
                this.seekBar.max = this.audio.duration;
                this.updateTimeDisplay();
            }
        }
        
        updateTimeDisplay() {
            const current = this.formatTime(this.audio.currentTime);
            const duration = this.formatTime(this.audio.duration);
            this.timeDisplay.textContent = `${current} / ${duration}`;
        }
        
        formatTime(seconds) {
            if (isNaN(seconds) || !isFinite(seconds)) return '0:00';
            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60);
            return `${mins}:${secs.toString().padStart(2, '0')}`;
        }
        
        onEnded() { this.playPauseBtn.textContent = '▶'; this.isPlaying = false; }
        onCanPlay() { if (this.errorSpan) this.errorSpan.textContent = ''; }
        onError(e) { console.warn('Audio error:', e); this.playPauseBtn.textContent = '✖'; if (this.errorSpan) this.errorSpan.textContent = '❌ load failed'; }
    }
    
