    const smIcon = 'https://aibel.ru/media/chars/ava/img20260421133157_32736372.gif';
    const pageElements = [];

    for (let i = 0; i < pagesData.length; i++) {
        const page = pagesData[i];
        const isJM = page.author === "JM";
        const icon = isJM ? jmIcon : smIcon;
        const smClass = isJM ? "" : "sm-style";
        const pageDiv = document.createElement('div');
        pageDiv.id = `page${i+1}`;
        pageDiv.className = 'story-page';
        if (i !== 0) pageDiv.style.display = 'none';
        pageDiv.innerHTML = `<div class="icon-user-row"><img src="${icon}" alt="${page.author} icon"><span class="username">${page.author}</span></div><div class="story-text ${smClass}" id="storyText${i+1}">${page.text}</div><div class="page-number">page ${i+1} of ${TOTAL_PAGES}</div><div class="nav-arrow">${i > 0 ? '<button class="arrow-btn">←</button>' : ''}${i < pagesData.length - 1 ? '<button class="arrow-btn">→</button>' : ''}</div>`;
        storySection.appendChild(pageDiv);
        pageElements.push(pageDiv);
        applyCursiveFormatting(document.getElementById(`storyText${i+1}`));
        if (i > 0) pageDiv.querySelector('.nav-arrow .arrow-btn:first-child')?.addEventListener('click', () => showPage(i - 1));
        if (i < pagesData.length - 1) pageDiv.querySelector('.nav-arrow .arrow-btn:last-child')?.addEventListener('click', () => showPage(i + 1));
    }
    
    const resetBtn = document.createElement('button');
    resetBtn.id = 'resetBtn';
    resetBtn.className = 'reset-button';
    resetBtn.textContent = '[ lock screen ]';
    storySection.appendChild(resetBtn);
    
    let currentPageIndex = 0;
    function showPage(index) {
        if (index < 0) index = 0;
        if (index >= pageElements.length) index = pageElements.length - 1;
        pageElements.forEach(p => p.style.display = 'none');
        pageElements[index].style.display = 'block';
        currentPageIndex = index;
    }
    
    window.addEventListener('keydown', (e) => {
        if (storySection.style.display === 'flex') {
            if (e.key === 'ArrowLeft') { e.preventDefault(); if (currentPageIndex > 0) showPage(currentPageIndex - 1); }
            else if (e.key === 'ArrowRight') { e.preventDefault(); if (currentPageIndex < pageElements.length - 1) showPage(currentPageIndex + 1); }
        }
    });
    
    document.querySelectorAll('#tocList a').forEach(link => {
        link.addEventListener('click', () => {
            const targetPage = parseInt(link.getAttribute('data-page'), 10);
            if (!isNaN(targetPage) && targetPage >= 0 && targetPage < pageElements.length && storySection.style.display === 'flex') showPage(targetPage);
        });
    });
    
    const gateSection = document.getElementById('gateSection');
    const passwordInput = document.getElementById('passwordInput');
    const submitBtn = document.getElementById('submitBtn');
    const errorMsgDiv = document.getElementById('errorMsg');
    const storySectionElem = document.getElementById('storySection');
    const tocContainer = document.getElementById('tocContainer');
    const playlistBox = document.getElementById('playlistContainer');
    
    function unlockContent() {
        gateSection.style.display = 'none';
        storySectionElem.style.display = 'flex';
        if (tocContainer) tocContainer.classList.add('visible');
        if (playlistBox) playlistBox.classList.add('visible');
        showPage(0);
        if (errorMsgDiv) errorMsgDiv.style.display = 'none';
    }
    
    function lockContent() {
        gateSection.style.display = 'flex';
        storySectionElem.style.display = 'none';
        if (tocContainer) tocContainer.classList.remove('visible');
        if (playlistBox) playlistBox.classList.remove('visible');
        if (passwordInput) { passwordInput.value = ''; passwordInput.focus(); }
        if (errorMsgDiv) errorMsgDiv.style.display = 'none';
        showPage(0);
    }
    
    async function handlePasswordSubmit() {
        const enteredPassword = passwordInput.value;
        const enteredHash = await hashPassword(enteredPassword);
        if (enteredHash === CORRECT_HASH) {
            unlockContent();
        } else {
            errorMsgDiv.style.display = 'block';
            errorMsgDiv.innerText = '[ access denied ]';
            setTimeout(() => { if (errorMsgDiv && gateSection.style.display !== 'none') errorMsgDiv.style.display = 'none'; }, 2000);
            passwordInput.value = '';
            passwordInput.focus();
        }
    }
    
    submitBtn.addEventListener('click', handlePasswordSubmit);
    passwordInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') { e.preventDefault(); handlePasswordSubmit(); } });
    const globalReset = document.getElementById('resetBtn');
    if (globalReset) globalReset.addEventListener('click', lockContent);
    
    window.addEventListener('DOMContentLoaded', () => { lockContent(); renderPlaylist(); });
    
    window.pagesData = pagesData;
    window.showPage = showPage;
    window.addTrack = addTrack;
